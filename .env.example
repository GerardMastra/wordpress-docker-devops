# ==========================================
# Environment configuration example
# Copy this file to .env.local or .env.prod
# and replace values with your own
# ==========================================

# ===== Runtime =====
RUNTIME_DIR=/opt/wordpress-runtime

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=change_me_wp

# ===== Domain & SSL =====
DOMAIN_NAME=example.local
SSL_EMAIL=admin@example.com

# ===== WordPress =====
WP_TABLE_PREFIX=wp_
WP_DEBUG=false

WP_HOME=http://example.local
WP_SITEURL=http://example.local

# ===== S3 Configuration (optional for bootstrap restore) =====
S3_BUCKET=your-bucket-name
S3_PATH_WP=bootstrap/wordpress/wp-content.tar.gz
S3_PATH_DB=bootstrap/mysql/mysql-bootstrap.tar.gz

# ===== DockerHub =====
DOCKERHUB_USERNAME=gerardmastra
