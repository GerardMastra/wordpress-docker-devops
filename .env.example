# ==========================================
# GLOBAL ENVIRONMENT VARIABLES (ALL ENVS)
# Copy this file to:
# - .env.local (development)
# - .env.prod (production)
# - .env.backup (testing)
# ==========================================

# ===== ENV CONTROL =====
# Possible values: local | prod | backup

ENV=

# Define which env file docker-compose should use

ENV_FILE=

# Disable S3 (true for local, false for prod)

DISABLE_S3=

# Runtime directory (EC2 or local volume)

RUNTIME_DIR=

# ===== MySQL =====

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# ===== Domain & SSL =====

DOMAIN_NAME=
SSL_EMAIL=

# ===== WordPress =====

WP_TABLE_PREFIX=
WP_DEBUG=

WP_HOME=
WP_SITEURL=

# ===== S3 Configuration (ONLY if using backups/bootstrap) =====

S3_BUCKET=
S3_PATH_WP=
S3_PATH_DB=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# ===== DockerHub =====

DOCKERHUB_USERNAME=

# ==========================================
# NOTES BY ENVIRONMENT
# ==========================================

# LOCAL:
# - ENV=local
# - DOMAIN_NAME=example.local
# - AWS credentials required

# PROD:
# - ENV=prod
# - Use real domain + SSL
# - AWS credentials required

# BACKUP:
# - ENV=backup
# - DISABLE_S3=true
# - Used for test
