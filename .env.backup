# ===== ENV CONTROL =====
ENV=local
ENV_FILE=.env.backup
DISABLE_S3=true

# ===== PATHS =====
RUNTIME_DIR=/opt/wordpress-runtime

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=changeme_wp

# ===== WordPress =====
WP_TABLE_PREFIX=wp_
WP_DEBUG=false

WP_HOME=http://localhost
WP_SITEURL=http://localhost

# ===== SSL (no usado pero requerido por compose) =====
SSL_EMAIL=test@local
DOMAIN_NAME=localhost

# ===== S3 (dummy) =====
S3_BUCKET=dummy-bucket
S3_PATH_WP=dummy/wp.tar.gz
S3_PATH_DB=dummy/db.tar.gz

# ===== DockerHub =====
DOCKERHUB_USERNAME=gerardmastra
